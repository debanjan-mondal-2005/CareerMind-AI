# ==========================================
# GROQ API Configuration (Primary LLM)
# ==========================================
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Specify a custom GROQ model
# Default: llama3-8b-8192 (very fast and free)
# GROQ_MODEL=llama3-8b-8192

# ==========================================
# Hugging Face Configuration (Simple Chat)
# ==========================================
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Optional: Specify a custom HF model for simple chat
# If not set, will try: Mistral-7B-Instruct-v0.2 -> Falcon-7B -> Llama-2 -> GPT2
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# ==========================================
# Database Configuration (Optional)
# ==========================================
# DATABASE_URL=sqlite:///./career_mind.db

# ==========================================
# Setup Instructions:
# ==========================================
# 1. Create a .env file in the root directory (copy this file)
# 2. Replace placeholders with your actual API keys
# 3. Get GROQ key from https://console.groq.com (free)
# 4. Get HF token from https://huggingface.co/settings/tokens
#
# If your HF token has limited access, the app will automatically
# fall back to other available models or built-in responses.
#
# NOTE: GROQ_API_KEY is REQUIRED for the app to work.
#       HF_TOKEN is optional - if missing, simple chat will use fallback responses.
